# Admin panel password — set something strong in production
ADMIN_PASSWORD="changeme"

# Data source: "local" = read from data/family.json | "api" = read from PostgreSQL
NEXT_PUBLIC_DATA_SOURCE="api"

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres:password@localhost:5432/family_tree"

NEXT_PUBLIC_AUDIT_LOGS_ENABLED=true
